% ----- Dimensions -----
\newlength{\secnumwidth}
\setlength{\secnumwidth}{2.8em}          % width of number inside its box
\newlength{\seclabelsep}
\setlength{\seclabelsep}{1.2em}          % space between number box and title box

% ----- Total width of number box (including its padding) -----
\newlength{\numfullwidth}
\setlength{\numfullwidth}{\secnumwidth + 2\fboxsep}

% ----- Number box (primary_blue background) -----
\newcommand{\sectionnumbox}[1]{%
  \colorbox{primary_blue}{%
    \makebox[\secnumwidth][c]{%
      \normalfont\sffamily\bfseries\large\color{white}#1%
    }%
  }%
}

% ----- Title box (cream background) for numbered sections -----
\newcommand{\sectiontitleboxnumbered}[1]{%
  \colorbox{cream}{%
    \parbox[c][2.4ex][c]{%
      \dimexpr\linewidth-\numfullwidth-\seclabelsep-2\fboxsep\relax
    }{%
      \centering\normalfont\sffamily\bfseries\color{primary_blue}#1%
    }%
  }%
}

% ----- Title box for unnumbered sections (full width) -----
\newcommand{\sectiontitleboxstar}[1]{%
  \colorbox{cream}{%
    \parbox[c][2.4ex][c]{\dimexpr\linewidth-2\fboxsep\relax}{%
      \centering\normalfont\sffamily\bfseries\color{primary_blue}#1%
    }%
  }%
}

% ----- Numbered sections -----
\titleformat{\section}
  {\normalfont}
  {\sectionnumbox{\thesection}}          % label
  {\seclabelsep}                           % space between label and title
  {\sectiontitleboxnumbered}                % before-code (receives title as #1)
  [\vspace{2pt}{\color{turquoise}\rule{\textwidth}{0.5pt}}] % after-code

\titlespacing*{\section}{0pt}{3.5ex plus 1ex minus .2ex}{2.3ex plus .2ex}

% ----- Unnumbered sections -----
\titleformat{name=\section,numberless}
  {\normalfont}
  {}
  {0pt}
  {\sectiontitleboxstar}
  [\vspace{2pt}{\color{turquoise}\rule{\textwidth}{0.5pt}}]
